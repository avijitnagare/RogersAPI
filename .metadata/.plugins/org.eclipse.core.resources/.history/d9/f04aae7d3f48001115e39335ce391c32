package com.infy.roger.utility;

import org.springframework.stereotype.Component;

@Component
public class DataDump implements CommandLineRunner {

    private final ProductRepository repository;

    public DataInitializer(ProductRepository repository) {
        this.repository = repository;
    }

    @Override
    public void run(String... args) throws Exception {
        List<Product> products = new ArrayList<>();
        
        for (int i = 1; i <= 200; i++) {
            products.add(new Product("Product " + i));
        }

        repository.saveAll(products);
        System.out.println("Successfully pre-loaded 200 products into H2!");
    }
}